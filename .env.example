# SiliconFlow API
SILICONFLOW_API_KEY=sk-your-siliconflow-key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Model tiers
SILICONFLOW_CHAT_MODEL=Qwen/Qwen3.5-397B-A17B
SILICONFLOW_FAST_MODEL=Qwen/Qwen3-30B-A3B
SILICONFLOW_SUMMARY_MODEL=deepseek-ai/DeepSeek-V4-Flash
SILICONFLOW_REVIEW_MODEL=Qwen/Qwen3.6-27B
SILICONFLOW_MERGE_MODEL=Qwen/Qwen3.6-27B

# Docling remote parser
DOCLING_MODE=remote
DOCLING_BASE_URL=http://127.0.0.1:5001
DOCLING_TIMEOUT_SECONDS=360

# Web search fallback for Wiki Chat: off | duckduckgo
WEB_SEARCH_MODE=duckduckgo
WEB_SEARCH_TIMEOUT_SECONDS=5
WEB_SEARCH_MAX_RESULTS=5

# Storage backend: local | oss
STORAGE_BACKEND=local
STORAGE_ROOT_PREFIX=users/admin

# Aliyun OSS, used only when STORAGE_BACKEND=oss
OSS_ENDPOINT=https://oss-cn-shenzhen.aliyuncs.com
OSS_BUCKET=your-oss-bucket
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
